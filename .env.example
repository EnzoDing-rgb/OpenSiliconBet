# API Configuration
# Copy this file to .env and fill in your values
#
# API_PROTOCOL:
# - "openai": OpenAI-compatible Chat Completions
# - "anthropic": Anthropic-compatible Messages API (e.g. Volcengine Ark gateway)
API_PROTOCOL=anthropic

# Volcengine Ark (Anthropic-compatible)
API_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
API_KEY=ark-your-api-key-here
MODEL=ark-code-latest

# Alternative: Volcengine Ark OpenAI-compatible gateway (if you prefer /chat/completions style)
# API_PROTOCOL=openai
# API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# API_KEY=ark-your-api-key-here
# MODEL=ark-code-latest

# Alternative: Volcengine Ark OpenAI-compatible gateway (if you prefer /chat/completions style)
# API_PROTOCOL=openai
# API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# API_KEY=ark-your-api-key-here
# MODEL=ark-code-latest
