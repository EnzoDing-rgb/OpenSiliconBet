# API Configuration
# Copy this file to .env and fill in your values
#
# API_PROTOCOL:
# - "openai": OpenAI-compatible Chat Completions
# - "anthropic": Anthropic-compatible Messages API
API_PROTOCOL=openai

# Volcengine Ark (OpenAI-compatible)
API_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
API_KEY=ark-your-api-key-here
MODEL=ark-code-latest

# Alternative: Volcengine Ark OpenAI-compatible gateway (if you prefer /chat/completions style)
# API_PROTOCOL=openai
# API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# API_KEY=ark-your-api-key-here
# MODEL=ark-code-latest

# Alternative: Volcengine Ark OpenAI-compatible gateway (if you prefer /chat/completions style)
# API_PROTOCOL=openai
# API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# API_KEY=ark-your-api-key-here
# MODEL=ark-code-latest

# --- LLM fallback (debate_runner: local Qwen when Ark returns 429 / AccountQuotaExceeded) ---
# LLM_FALLBACK_DISABLED=1
# LLM_FALLBACK_BASE_URL=http://127.0.0.1:30019/v1
# LLM_FALLBACK_API_KEY=my-local-secret-key
# LLM_FALLBACK_MODEL=qwen3.5

# --- Optional: Aliyun DashScope TTS (only required if you enable DebateAudio/TTS) ---
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# 过渡期：只填一个默认克隆即可全员复用（任选其一）
# VOICE_ID_DEFAULT=your-voice-id
# 兼容旧 .env：VOICE_ID_MEARSHEIMER / VOICE_ID_JERVIS 仍可作默认回退
# VOICE_ID_MEARSHEIMER=your-voice-id
# 分角色（可选；留空则退回 VOICE_ID_DEFAULT → MEARSHEIMER → JERVIS）
# 五辩手：可将 enrollment 音频放 assets/ 后运行 python3 scripts/enroll_voices.py 自动写入下列五键
# VOICE_ID_LEX=
# VOICE_ID_WUWEI=
# VOICE_ID_LIPTAN=
# VOICE_ID_COOK=
# VOICE_ID_JENSEN=
# TTS_MODEL=qwen3-tts-vc-realtime-2026-01-15
# TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
